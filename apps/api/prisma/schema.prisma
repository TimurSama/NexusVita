// ============================================================================
// МОДУЛЬ ЕЖЕДНЕВНЫХ ПРИВЫЧЕК
// ============================================================================

enum HabitFrequency {
  DAILY
  WEEKLY
  SPECIFIC_DAYS
  CUSTOM
}

model Habit {
  id              String          @id @default(uuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title           String
  description     String?
  icon            String?         // Emoji или иконка
  color           String?         // Цвет для UI
  
  // Частота
  frequency       HabitFrequency
  targetDays      Int[]           // [1,2,3,4,5] - пн-пт для SPECIFIC_DAYS
  timesPerDay     Int             @default(1)
  
  // Время напоминания
  reminderTime    String?         // "08:00"
  reminderEnabled Boolean         @default(true)
  
  // Цель
  targetStreak    Int?            // Целевая серия дней
  targetTotal     Int?            // Целевое общее количество
  
  // Статистика
  currentStreak   Int             @default(0)
  longestStreak   Int             @default(0)
  totalCompletions Int            @default(0)
  
  // Категория
  category        String?         // "здоровье", "продуктивность", "развитие"
  
  // Награда за выполнение
  tokensPerCompletion Decimal     @default(0) @db.Decimal(18, 8)
  
  isActive        Boolean         @default(true)
  isArchived      Boolean         @default(false)
  
  logs            HabitLog[]
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([userId, isActive])
}

model HabitLog {
  id              String    @id @default(uuid())
  habitId         String
  habit           Habit     @relation(fields: [habitId], references: [id], onDelete: Cascade)
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  date            DateTime  @db.Date
  completedAt     DateTime?
  
  // Если привычка выполняется несколько раз в день
  completionCount Int       @default(0)
  targetCount     Int       @default(1)
  
  isCompleted     Boolean   @default(false)
  
  notes           String?
  mood            Int?      // 1-5 настроение при выполнении
  
  tokensEarned    Decimal   @default(0) @db.Decimal(18, 8)
  
  createdAt       DateTime  @default(now())
  
  @@unique([habitId, date])
  @@index([userId, date])
}

// ============================================================================
// МОДУЛЬ БЫТА И ОБРАЗА ЖИЗНИ
// ============================================================================

model DailyRoutine {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  date            DateTime  @db.Date
  
  // Основные временные точки
  wakeUpTime      DateTime?
  bedTime         DateTime?
  workStartTime   DateTime?
  workEndTime     DateTime?
  
  // Активности дня
  activities      Json?     // [{time: "08:00", activity: "завтрак", duration: 30}]
  
  // Оценка дня
  productivityScore Int?    // 1-10
  energyScore     Int?      // 1-10
  stressScore     Int?      // 1-10
  balanceScore    Int?      // 1-10 work-life баланс
  
  // Экранное время
  screenTimeMinutes Int?
  
  // Выход на улицу / природа
  outdoorMinutes  Int?
  sunlightMinutes Int?
  
  // Социальные взаимодействия
  socialInteractions Int?   // Количество
  qualityTimeMinutes Int?   // Время с близкими
  
  notes           String?   @db.Text
  highlights      String[]  // Главные события дня
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@unique([userId, date])
  @@index([userId, date])
}

model SleepLog {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  date            DateTime  @db.Date
  
  bedTime         DateTime
  wakeUpTime      DateTime
  
  // Длительность (вычисляется)
  totalSleepMinutes Int
  
  // Качество
  sleepQuality    Int       // 1-10
  
  // Фазы сна (с устройств)
  deepSleepMinutes Int?
  lightSleepMinutes Int?
  remSleepMinutes Int?
  awakeMinutes    Int?
  
  // Субъективные данные
  fellAsleepQuickly Boolean?
  wokeUpRested    Boolean?
  hadDreams       Boolean?
  nightmares      Boolean?
  
  // Факторы
  caffeine        Boolean?  @default(false)
  alcohol         Boolean?  @default(false)
  lateExercise    Boolean?  @default(false)
  screenBefore    Boolean?  @default(false)
  
  notes           String?
  
  // Данные с устройств
  deviceData      Json?
  heartRateData   Json?
  
  tokensEarned    Decimal   @default(0) @db.Decimal(18, 8)
  
  createdAt       DateTime  @default(now())
  
  @@unique([userId, date])
  @@index([userId, date])
}

// ============================================================================
// МОДУЛЬ ОБРАЗОВАНИЯ (ЦЕНТР ЗНАНИЙ)
// ============================================================================

enum ContentType {
  ARTICLE
  VIDEO
  AUDIO
  PODCAST
  COURSE
  WEBINAR
  BOOK
  INFOGRAPHIC
  CHECKLIST
}

model Course {
  id              String             @id @default(uuid())
  authorId        String             // ID специалиста
  
  title           String
  description     String?            @db.Text
  shortDescription String?
  coverImageUrl   String?
  
  // Категоризация
  category        String             // "фитнес", "питание", "психология"
  subcategory     String?
  tags            String[]
  
  difficulty      DifficultyLevel
  duration        Int                // Общая длительность в минутах
  
  // Контент
  lessons         Lesson[]
  
  // Цены
  isFree          Boolean            @default(false)
  isPremium       Boolean            @default(false)
  priceFiat       Decimal?           @db.Decimal(10, 2)
  priceTokens     Decimal?           @db.Decimal(18, 8)
  
  // Статистика
  enrollmentsCount Int               @default(0)
  completionsCount Int               @default(0)
  rating          Float              @default(0)
  reviewsCount    Int                @default(0)
  
  // Сертификация
  hasCertificate  Boolean            @default(false)
  
  enrollments     CourseEnrollment[]
  
  isPublished     Boolean            @default(false)
  publishedAt     DateTime?
  
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  
  @@index([category])
  @@index([isPublished])
}

model Lesson {
  id              String             @id @default(uuid())
  courseId        String
  course          Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  
  title           String
  description     String?
  
  orderIndex      Int
  
  // Контент
  contentType     ContentType
  contentUrl      String?            // URL видео/аудио
  textContent     String?            @db.Text
  
  duration        Int?               // В минутах
  
  // Материалы
  attachments     Json?              // Дополнительные файлы
  
  // Задания
  hasQuiz         Boolean            @default(false)
  quizQuestions   Json?
  
  isFree          Boolean            @default(false) // Доступен без покупки курса
  
  completions     LessonCompletion[]
  
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model CourseEnrollment {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId        String
  course          Course    @relation(fields: [courseId], references: [id])
  
  enrolledAt      DateTime  @default(now())
  
  progress        Float     @default(0) // Процент
  lastAccessedAt  DateTime?
  
  isCompleted     Boolean   @default(false)
  completedAt     DateTime?
  
  // Сертификат
  certificateId   String?
  certificateUrl  String?
  
  // Оценка
  rating          Int?
  review          String?
  
  @@unique([userId, courseId])
}

model LessonCompletion {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId        String
  lesson          Lesson    @relation(fields: [lessonId], references: [id])
  
  completedAt     DateTime  @default(now())
  
  // Результаты теста
  quizScore       Float?
  quizAttempts    Int       @default(0)
  
  timeSpentMinutes Int?
  
  @@unique([userId, lessonId])
}

model Article {
  id              String      @id @default(uuid())
  authorId        String
  
  title           String
  slug            String      @unique
  excerpt         String?
  content         String      @db.Text
  
  coverImageUrl   String?
  
  category        String
  tags            String[]
  
  // Статистика
  viewsCount      Int         @default(0)
  likesCount      Int         @default(0)
  commentsCount   Int         @default(0)
  
  // Доступ
  isFree          Boolean     @default(true)
  isPremium       Boolean     @default(false)
  
  isPublished     Boolean     @default(false)
  publishedAt     DateTime?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@index([slug])
  @@index([category])
}

// ============================================================================
// МОДУЛЬ СОЦИАЛЬНОЙ СЕТИ
// ============================================================================

enum PostType {
  TEXT
  IMAGE
  VIDEO
  STORY
  POLL
  WORKOUT_SHARE
  ACHIEVEMENT_SHARE
  MEAL_SHARE
}

model Post {
  id              String    @id @default(uuid())
  authorId        String
  author          User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  type            PostType  @default(TEXT)
  
  content         String?   @db.Text
  mediaUrls       String[]
  
  // Для шейринга активностей
  sharedItemType  String?   // "workout", "achievement", "meal"
  sharedItemId    String?
  
  // Видимость
  visibility      String    @default("public") // public, followers, private
  
  // Статистика
  likesCount      Int       @default(0)
  commentsCount   Int       @default(0)
  sharesCount     Int       @default(0)
  viewsCount      Int       @default(0)
  
  comments        Comment[]
  likes           Like[]
  
  // Теги и упоминания
  tags            String[]
  mentionedUsers  String[]  // ID упомянутых пользователей
  
  isEdited        Boolean   @default(false)
  isPinned        Boolean   @default(false)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([authorId])
  @@index([createdAt])
}

model Comment {
  id              String    @id @default(uuid())
  postId          String
  post            Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId        String
  author          User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  // Для вложенных комментариев
  parentId        String?
  parent          Comment?  @relation("commentReplies", fields: [parentId], references: [id])
  replies         Comment[] @relation("commentReplies")
  
  content         String    @db.Text
  
  likesCount      Int       @default(0)
  
  likes           Like[]
  
  isEdited        Boolean   @default(false)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([postId])
  @@index([authorId])
}

model Like {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  postId          String?
  post            Post?     @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId       String?
  comment         Comment?  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime  @default(now())
  
  @@unique([userId, postId])
  @@unique([userId, commentId])
}

model Follow {
  id              String    @id @default(uuid())
  followerId      String
  follower        User      @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  followingId     String
  following       User      @relation("followers", fields: [followingId], references: [id], onDelete: Cascade)
  
  // Тип подписки
  isPaid          Boolean   @default(false)
  subscriptionTier String?  // "free", "basic", "premium"
  
  createdAt       DateTime  @default(now())
  
  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// ============================================================================
// МОДУЛЬ ГРУПП И СООБЩЕСТВ
// ============================================================================

model Group {
  id              String        @id @default(uuid())
  creatorId       String
  creator         User          @relation("groupCreator", fields: [creatorId], references: [id])
  
  name            String
  slug            String        @unique
  description     String?       @db.Text
  coverImageUrl   String?
  avatarUrl       String?
  
  // Настройки
  isPrivate       Boolean       @default(false)
  requiresApproval Boolean      @default(false)
  
  // Категория
  category        String?       // "фитнес", "питание", "психология"
  tags            String[]
  
  // Статистика
  membersCount    Int           @default(0)
  postsCount      Int           @default(0)
  
  // Правила
  rules           String?       @db.Text
  
  members         GroupMember[]
  
  isActive        Boolean       @default(true)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([slug])
  @@index([category])
}

model GroupMember {
  id              String    @id @default(uuid())
  groupId         String
  group           Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  role            String    @default("member") // member, moderator, admin
  
  joinedAt        DateTime  @default(now())
  
  // Статистика участия
  postsCount      Int       @default(0)
  commentsCount   Int       @default(0)
  
  isMuted         Boolean   @default(false)
  isBanned        Boolean   @default(false)
  
  @@unique([groupId, userId])
}

// ============================================================================
// МОДУЛЬ ЧЕЛЛЕНДЖЕЙ И СОРЕВНОВАНИЙ
// ============================================================================

enum ChallengeType {
  STEPS
  WORKOUTS
  MEDITATION
  HABITS
  WEIGHT_LOSS
  CUSTOM
}

model Challenge {
  id              String              @id @default(uuid())
  creatorId       String
  
  title           String
  description     String?             @db.Text
  coverImageUrl   String?
  
  type            ChallengeType
  
  // Целевые метрики
  targetMetric    String              // "steps", "workouts", "minutes"
  targetValue     Float
  
  // Период
  startDate       DateTime
  endDate         DateTime
  
  // Участие
  isPublic        Boolean             @default(true)
  maxParticipants Int?
  minParticipants Int?
  
  // Награды
  rewardTokens    Decimal             @default(0) @db.Decimal(18, 8)
  rewardNftId     String?             // NFT-приз
  badges          String[]            // ID достижений
  
  // Статистика
  participantsCount Int               @default(0)
  completedCount  Int                 @default(0)
  
  participants    ChallengeParticipant[]
  
  isActive        Boolean             @default(true)
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model ChallengeParticipant {
  id              String    @id @default(uuid())
  challengeId     String
  challenge       Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  joinedAt        DateTime  @default(now())
  
  // Прогресс
  currentValue    Float     @default(0)
  progress        Float     @default(0) // Процент
  
  // Позиция в лидерборде
  rank            Int?
  
  isCompleted     Boolean   @default(false)
  completedAt     DateTime?
  
  // Награды
  rewardReceived  Boolean   @default(false)
  tokensEarned    Decimal   @default(0) @db.Decimal(18, 8)
  
  @@unique([challengeId, userId])
}

model Achievement {
  id              String            @id @default(uuid())
  
  name            String
  description     String
  
  iconUrl         String?
  badgeImageUrl   String?
  
  // Критерии получения
  criteria        Json              // {type: "workouts", count: 100}
  
  // Награда
  rewardTokens    Decimal           @default(0) @db.Decimal(18, 8)
  
  // NFT связь (опционально)
  isNft           Boolean           @default(false)
  nftContractAddress String?
  nftTokenId      String?
  
  // Бонусы от достижения
  benefits        Json?             // Скидки, доступы и т.п.
  
  // Редкость
  rarity          String            @default("common") // common, rare, epic, legendary
  
  users           UserAchievement[]
  
  isActive        Boolean           @default(true)
  
  createdAt       DateTime          @default(now())
}

model UserAchievement {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId   String
  achievement     Achievement @relation(fields: [achievementId], references: [id])
  
  earnedAt        DateTime    @default(now())
  
  // NFT данные
  nftMinted       Boolean     @default(false)
  nftTokenId      String?
  nftTxHash       String?
  
  @@unique([userId, achievementId])
}

// ============================================================================
// МОДУЛЬ СООБЩЕНИЙ И ЧАТОВ
// ============================================================================

enum ChatType {
  PRIVATE
  GROUP
  SUPPORT
  CONSULTATION
}

model Chat {
  id              String       @id @default(uuid())
  
  type            ChatType
  
  // Для групповых чатов
  name            String?
  avatarUrl       String?
  
  // Telegram интеграция
  telegramChatId  String?      @unique
  
  members         ChatMember[]
  messages        Message[]
  
  lastMessageAt   DateTime?
  
  isActive        Boolean      @default(true)
  
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model ChatMember {
  id              String    @id @default(uuid())
  chatId          String
  chat            Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  role            String    @default("member") // member, admin
  
  joinedAt        DateTime  @default(now())
  
  // Настройки
  isMuted         Boolean   @default(false)
  lastReadAt      DateTime?
  
  unreadCount     Int       @default(0)
  
  @@unique([chatId, userId])
}

model Message {
  id              String    @id @default(uuid())
  chatId          String
  chat            Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId        String
  sender          User      @relation("sender", fields: [senderId], references: [id])
  
  // Для личных сообщений
  receiverId      String?
  receiver        User?     @relation("receiver", fields: [receiverId], references: [id])
  
  content         String    @db.Text
  
  // Вложения
  attachments     Json?     // [{type: "image", url: "..."}]
  
  // Источник
  source          String    @default("app") // app, telegram
  telegramMsgId   String?
  
  isEdited        Boolean   @default(false)
  isDeleted       Boolean   @default(false)
  
  readAt          DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([chatId, createdAt])
}

// ============================================================================
// МОДУЛЬ УВЕДОМЛЕНИЙ
// ============================================================================

enum NotificationType {
  SYSTEM
  SOCIAL
  WORKOUT
  HEALTH
  ACHIEVEMENT
  CHALLENGE
  MESSAGE
  REMINDER
  PAYMENT
  PROMOTION
}

model Notification {
  id              String           @id @default(uuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type            NotificationType
  
  title           String
  body            String
  
  // Данные для перехода
  actionType      String?          // "open_workout", "open_chat", etc.
  actionData      Json?            // {workoutId: "...", chatId: "..."}
  
  imageUrl        String?
  
  isRead          Boolean          @default(false)
  readAt          DateTime?
  
  // Каналы доставки
  sentViaEmail    Boolean          @default(false)
  sentViaPush     Boolean          @default(false)
  sentViaTelegram Boolean          @default(false)
  
  createdAt       DateTime         @default(now())
  
  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model NotificationSettings {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Каналы
  emailEnabled    Boolean   @default(true)
  pushEnabled     Boolean   @default(true)
  telegramEnabled Boolean   @default(true)
  
  // Типы уведомлений
  socialEnabled   Boolean   @default(true)
  workoutReminders Boolean  @default(true)
  healthAlerts    Boolean   @default(true)
  achievementAlerts Boolean @default(true)
  challengeUpdates Boolean  @default(true)
  messageAlerts   Boolean   @default(true)
  promotions      Boolean   @default(false)
  
  // Тихие часы
  quietHoursEnabled Boolean @default(false)
  quietHoursStart String?   // "22:00"
  quietHoursEnd   String?   // "08:00"
  
  updatedAt       DateTime  @updatedAt
}

// ============================================================================
// МОДУЛЬ МАРКЕТПЛЕЙСА
// ============================================================================

enum ProductType {
  PHYSICAL
  DIGITAL
  SERVICE
  SUBSCRIPTION
  NFT
}

enum ProductCategory {
  WORKOUT_PROGRAM
  MEAL_PLAN
  COURSE
  CONSULTATION
  EQUIPMENT
  SUPPLEMENTS
  CLOTHING
  ACCESSORIES
  GIFT_CARD
  OTHER
}

model Product {
  id              String          @id @default(uuid())
  sellerId        String          // ID продавца (тренер, партнер)
  
  name            String
  slug            String          @unique
  description     String?         @db.Text
  shortDescription String?
  
  type            ProductType
  category        ProductCategory
  tags            String[]
  
  // Изображения
  images          String[]
  thumbnailUrl    String?
  
  // Цены
  priceFiat       Decimal         @db.Decimal(10, 2)
  priceTokens     Decimal?        @db.Decimal(18, 8)
  
  // Скидки
  discountPercent Float?
  discountEndsAt  DateTime?
  
  // Для физических товаров
  stock           Int?
  sku             String?
  weight          Float?
  dimensions      Json?           // {length, width, height}
  
  // Для цифровых товаров
  digitalAssetUrl String?
  
  // Для подписок
  subscriptionPeriod String?      // "month", "year"
  
  // Статистика
  salesCount      Int             @default(0)
  rating          Float           @default(0)
  reviewsCount    Int             @default(0)
  
  orders          OrderItem[]
  
  isActive        Boolean         @default(true)
  isPublished     Boolean         @default(false)
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([slug])
  @@index([category])
  @@index([sellerId])
}

model Order {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  
  orderNumber     String      @unique
  
  items           OrderItem[]
  
  // Суммы
  subtotal        Decimal     @db.Decimal(10, 2)
  discount        Decimal     @default(0) @db.Decimal(10, 2)
  shipping        Decimal     @default(0) @db.Decimal(10, 2)
  total           Decimal     @db.Decimal(10, 2)
  
  // Оплата токенами
  tokenAmount     Decimal?    @db.Decimal(18, 8)
  
  // Статус
  status          String      @default("pending") // pending, paid, processing, shipped, delivered, cancelled, refunded
  
  // Оплата
  paymentMethod   String?     // "card", "tokens", "mixed"
  paymentStatus   String      @default("pending")
  paymentId       String?
  paidAt          DateTime?
  
  // Доставка (для физических товаров)
  shippingAddress Json?
  trackingNumber  String?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  
  // Промокод
  discountCode    String?
  discountId      String?
  
  notes           String?
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@index([userId])
  @@index([orderNumber])
}

model OrderItem {
  id              String    @id @default(uuid())
  orderId         String
  order           Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product   @relation(fields: [productId], references: [id])
  
  quantity        Int       @default(1)
  unitPrice       Decimal   @db.Decimal(10, 2)
  totalPrice      Decimal   @db.Decimal(10, 2)
  
  // Для цифровых товаров
  accessGranted   Boolean   @default(false)
  
  createdAt       DateTime  @default(now())
}

model Discount {
  id              String    @id @default(uuid())
  
  code            String    @unique
  description     String?
  
  discountType    String    // "percentage", "fixed", "tokens"
  value           Decimal   @db.Decimal(10, 2)
  
  // Ограничения
  minOrderAmount  Decimal?  @db.Decimal(10, 2)
  maxDiscount     Decimal?  @db.Decimal(10, 2)
  usageLimit      Int?
  usageCount      Int       @default(0)
  usageLimitPerUser Int?
  
  // Применимость
  applicableProducts String[] // ID продуктов или пусто для всех
  applicableCategories ProductCategory[]
  
  // Владелец (тренер, локация или платформа)
  ownerId         String?
  ownerType       String?   // "trainer", "location", "platform"
  
  // Период действия
  startsAt        DateTime  @default(now())
  expiresAt       DateTime?
  
  isActive        Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  
  @@index([code])
}

// ============================================================================
// МОДУЛЬ ЛОКАЦИЙ (ЗАЛЫ, КЛИНИКИ, СПА)
// ============================================================================

enum LocationType {
  GYM
  FITNESS_CENTER
  YOGA_STUDIO
  MEDICAL_CENTER
  SPA
  POOL
  SPORTS_COMPLEX
  OUTDOOR
  HOME
}

model Location {
  id              String            @id @default(uuid())
  ownerId         String            // ID владельца
  
  name            String
  slug            String            @unique
  description     String?           @db.Text
  
  type            LocationType
  
  // Контакты
  phone           String?
  email           String?
  website         String?
  
  // Адрес
  address         String
  city            String
  country         String
  postalCode      String?
  coordinates     Json?             // {lat, lng}
  
  // Медиа
  images          String[]
  coverImageUrl   String?
  logoUrl         String?
  
  // Часы работы
  workingHours    Json?             // {monday: {open: "08:00", close: "22:00"}, ...}
  
  // Удобства
  amenities       String[]          // ["душ", "сауна", "парковка"]
  
  // Статистика
  rating          Float             @default(0)
  reviewsCount    Int               @default(0)
  
  // Тренеры
  trainers        TrainerLocation[]
  
  // Абонементы
  subscriptions   LocationSubscription[]
  
  // Доступы пользователей
  userAccess      LocationAccess[]
  
  // Верификация
  isVerified      Boolean           @default(false)
  
  isActive        Boolean           @default(true)
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  @@index([slug])
  @@index([city])
}

model TrainerLocation {
  id              String         @id @default(uuid())
  trainerId       String
  trainer         TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  locationId      String
  location        Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  
  // Партнерские условия
  discountPercent Float?
  partnerDetails  Json?
  
  isActive        Boolean        @default(true)
  
  createdAt       DateTime       @default(now())
  
  @@unique([trainerId, locationId])
}

model LocationSubscription {
  id              String    @id @default(uuid())
  locationId      String
  location        Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  
  title           String
  description     String?
  
  // Период
  duration        Int       // В днях
  durationType    String    // "days", "months", "year"
  
  // Цены
  priceFiat       Decimal   @db.Decimal(10, 2)
  priceTokens     Decimal?  @db.Decimal(18, 8)
  
  // Ограничения
  visitsLimit     Int?      // Кол-во посещений (null = безлимит)
  
  // NFC/QR доступ
  nfcEnabled      Boolean   @default(true)
  qrEnabled       Boolean   @default(true)
  
  // Включено
  includedAmenities String[]
  
  isActive        Boolean   @default(true)
  
  userAccess      LocationAccess[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model LocationAccess {
  id                  String               @id @default(uuid())
  userId              String
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  locationId          String
  location            Location             @relation(fields: [locationId], references: [id])
  subscriptionId      String
  subscription        LocationSubscription @relation(fields: [subscriptionId], references: [id])
  
  // Период действия
  startsAt            DateTime
  expiresAt           DateTime
  
  // Использование
  visitsUsed          Int                  @default(0)
  visitsRemaining     Int?
  
  // QR/NFC код
  accessCode          String               @unique
  
  // История посещений
  visits              LocationVisit[]
  
  isActive            Boolean              @default(true)
  
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  
  @@index([userId])
  @@index([accessCode])
}

model LocationVisit {
  id              String          @id @default(uuid())
  accessId        String
  access          LocationAccess  @relation(fields: [accessId], references: [id], onDelete: Cascade)
  
  checkinAt       DateTime        @default(now())
  checkoutAt      DateTime?
  
  // Метод входа
  entryMethod     String          // "qr", "nfc", "manual"
  
  duration        Int?            // В минутах
  
  @@index([accessId, checkinAt])
}

// ============================================================================
// МОДУЛЬ ПОДПИСОК ПОЛЬЗОВАТЕЛЕЙ
// ============================================================================

model UserSubscription {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Тип подписки
  type            String    // "platform_premium", "trainer", "location"
  targetId        String?   // ID тренера/локации
  
  tier            String    // "basic", "pro", "premium"
  
  // Период
  startsAt        DateTime  @default(now())
  expiresAt       DateTime?
  
  // Оплата
  priceFiat       Decimal?  @db.Decimal(10, 2)
  priceTokens     Decimal?  @db.Decimal(18, 8)
  
  // Автопродление
  autoRenew       Boolean   @default(false)
  
  // Статус
  status          String    @default("active") // active, cancelled, expired
  cancelledAt     DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([userId, type])
}

// ============================================================================
// МОДУЛЬ WEB3 / DAO / ТОКЕНОМИКА
// ============================================================================

model StakingRecord {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  amount          Decimal   @db.Decimal(18, 8)
  
  // Тип стейкинга
  stakingType     String    // "governance", "premium_access", "pool"
  
  // Период
  stakedAt        DateTime  @default(now())
  lockPeriodDays  Int       // Период блокировки
  unlocksAt       DateTime
  
  // Награды
  rewardRate      Float     // APY в процентах
  earnedRewards   Decimal   @default(0) @db.Decimal(18, 8)
  lastRewardAt    DateTime?
  
  // Статус
  isActive        Boolean   @default(true)
  unstaked        Boolean   @default(false)
  unstakedAt      DateTime?
  
  // Blockchain данные
  txHash          String?
  contractAddress String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([userId])
}

model DaoProposal {
  id              String     @id @default(uuid())
  creatorId       String
  
  title           String
  description     String     @db.Text
  
  // Категория
  category        String     // "feature", "budget", "policy", "other"
  
  // Требуемый кворум
  quorum          Float      // Процент от общего стейка
  
  // Период голосования
  votingStartsAt  DateTime
  votingEndsAt    DateTime
  
  // Результаты
  votesFor        Decimal    @default(0) @db.Decimal(18, 8)
  votesAgainst    Decimal    @default(0) @db.Decimal(18, 8)
  votesAbstain    Decimal    @default(0) @db.Decimal(18, 8)
  votersCount     Int        @default(0)
  
  // Статус
  status          String     @default("active") // draft, active, passed, rejected, executed
  
  // Исполнение
  executionData   Json?
  executedAt      DateTime?
  executionTxHash String?
  
  votes           DaoVote[]
  
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model DaoVote {
  id              String      @id @default(uuid())
  proposalId      String
  proposal        DaoProposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  vote            String      // "for", "against", "abstain"
  votingPower     Decimal     @db.Decimal(18, 8) // Вес голоса (= стейк)
  
  // Делегирование (опционально)
  delegatedFrom   String?
  
  txHash          String?
  
  createdAt       DateTime    @default(now())
  
  @@unique([proposalId, userId])
}

model TokenTransaction {
  id              String    @id @default(uuid())
  
  fromUserId      String?
  toUserId        String?
  
  amount          Decimal   @db.Decimal(18, 8)
  
  // Тип транзакции
  type            String    // "reward", "payment", "stake", "unstake", "transfer", "purchase"
  
  // Описание
  description     String?
  
  // Связь с сущностью
  referenceType   String?   // "workout", "challenge", "order", "subscription"
  referenceId     String?
  
  // Blockchain
  txHash          String?
  blockNumber     Int?
  
  status          String    @default("completed") // pending, completed, failed
  
  createdAt       DateTime  @default(now())
  
  @@index([fromUserId])
  @@index([toUserId])
  @@index([type])
}

// NFT модели
model NftCollection {
  id              String    @id @default(uuid())
  
  name            String
  symbol          String
  description     String?   @db.Text
  
  contractAddress String    @unique
  chainId         Int
  
  // Тип коллекции
  collectionType  String    // "achievement", "certificate", "membership", "collectible"
  
  // Медиа
  coverImageUrl   String?
  bannerImageUrl  String?
  
  // Статистика
  totalSupply     Int       @default(0)
  holders         Int       @default(0)
  
  nfts            Nft[]
  
  isOfficial      Boolean   @default(false)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Nft {
  id              String        @id @default(uuid())
  collectionId    String
  collection      NftCollection @relation(fields: [collectionId], references: [id])
  
  tokenId         String
  
  name            String
  description     String?
  imageUrl        String?
  animationUrl    String?
  
  // Метаданные
  attributes      Json?
  
  // Владелец
  ownerId         String?
  
  // Рыночные данные
  isListed        Boolean       @default(false)
  listingPrice    Decimal?      @db.Decimal(18, 8)
  
  mintedAt        DateTime?
  mintTxHash      String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@unique([collectionId, tokenId])
}

// SBT (Soulbound Token) - непередаваемые
model SoulboundToken {
  id              String    @id @default(uuid())
  
  ownerId         String
  
  tokenType       String    // "reputation", "certification", "membership", "penalty"
  
  name            String
  description     String?
  imageUrl        String?
  
  // Данные
  data            Json?
  
  // Срок действия
  expiresAt       DateTime?
  isRevoked       Boolean   @default(false)
  revokedAt       DateTime?
  revokedReason   String?
  
  // Blockchain
  contractAddress String?
  tokenId         String?
  mintTxHash      String?
  
  issuedAt        DateTime  @default(now())
  
  @@index([ownerId])
  @@index([tokenType])
}

// ============================================================================
// ИНТЕГРАЦИИ С ГАДЖЕТАМИ
// ============================================================================

model DeviceIntegration {
  id              String    @id @default(uuid())
  userId          String
  
  // Провайдер
  provider        String    // "apple_health", "google_fit", "fitbit", "garmin", "whoop"
  
  // Авторизация
  accessToken     String?
  refreshToken    String?
  tokenExpiresAt  DateTime?
  
  // Устройства
  devices         Json?     // Список подключенных устройств
  
  // Синхронизация
  lastSyncAt      DateTime?
  syncEnabled     Boolean   @default(true)
  
  // Какие данные синхронизировать
  syncSteps       Boolean   @default(true)
  syncWorkouts    Boolean   @default(true)
  syncSleep       Boolean   @default(true)
  syncHeartRate   Boolean   @default(true)
  syncNutrition   Boolean   @default(false)
  
  isActive        Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@unique([userId, provider])
}

// ============================================================================
// TELEGRAM ИНТЕГРАЦИЯ
// ============================================================================

model TelegramUser {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  telegramId      String    @unique
  username        String?
  firstName       String?
  lastName        String?
  
  // Для Mini App
  miniAppEnabled  Boolean   @default(false)
  
  // Уведомления
  notificationsEnabled Boolean @default(true)
  
  // Авторизация
  authDate        DateTime?
  authHash        String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// ============================================================================
// РЕФЕРАЛЬНАЯ СИСТЕМА
// ============================================================================

model Referral {
  id              String    @id @default(uuid())
  
  referrerId      String    // Кто привел
  referrer        User      @relation("referrer", fields: [referrerId], references: [id])
  referredId      String    // Кого привели
  referred        User      @relation("referred", fields: [referredId], references: [id])
  
  // Код
  referralCode    String
  
  // Награды
  referrerReward  Decimal   @default(0) @db.Decimal(18, 8)
  referredReward  Decimal   @default(0) @db.Decimal(18, 8)
  
  // Статус
  status          String    @default("pending") // pending, confirmed, rewarded
  
  confirmedAt     DateTime?
  rewardedAt      DateTime?
  
  createdAt       DateTime  @default(now())
  
  @@unique([referrerId, referredId])
  @@index([referralCode])
}

model ReferralCode {
  id              String    @id @default(uuid())
  userId          String    @unique
  owner           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  code            String    @unique
  type            String    @default("USER") // USER, TRAINER, LOCATION, SHOP
  
  // Статистика
  usageCount      Int       @default(0)
  totalEarned     Decimal   @default(0) @db.Decimal(18, 8)
  
  isActive        Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
}

// ============================================================================
// ПАРТНЕРСКАЯ СИСТЕМА
// ============================================================================

model PartnerNetwork {
  id              String    @id @default(uuid())
  
  name            String
  description     String?   @db.Text
  
  // Участники сети
  members         PartnerNetworkMember[]
  
  // Тематика
  category        String    // "спортивная реабилитация", "похудение", "беременность"
  
  // Общие услуги
  services        Json?
  
  isActive        Boolean   @default(true)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model PartnerNetworkMember {
  id              String          @id @default(uuid())
  networkId       String
  network         PartnerNetwork  @relation(fields: [networkId], references: [id], onDelete: Cascade)
  
  // Участник (специалист или организация)
  memberId        String
  memberType      String          // "trainer", "doctor", "location", "specialist"
  
  role            String          @default("member") // member, lead
  
  // Реферальные условия
  referralCommission Float        @default(0.1) // 10%
  
  joinedAt        DateTime        @default(now())
  
  @@unique([networkId, memberId])
}

// ============================================================================
// СИСТЕМА ОТЗЫВОВ
// ============================================================================

model Review {
  id              String    @id @default(uuid())
  userId          String
  
  // Что оцениваем
  targetType      String    // "trainer", "doctor", "location", "product", "course"
  targetId        String
  
  rating          Int       // 1-5
  title           String?
  content         String?   @db.Text
  
  // Фото/видео
  mediaUrls       String[]
  
  // Ответ
  response        String?   @db.Text
  respondedAt     DateTime?
  
  // Полезность
  helpfulCount    Int       @default(0)
  
  isVerified      Boolean   @default(false) // Проверенная покупка/использование
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@unique([userId, targetType, targetId])
  @@index([targetType, targetId])
}

