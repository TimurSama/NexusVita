// Nexus Vita - Полная схема базы данных экосистемы
// Включает: пользователи, тренировки, медицина, питание, психология, 
// сексология, привычки, быт, образование, соцсеть, маркетплейс, Web3/DAO

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// МОДУЛЬ ПОЛЬЗОВАТЕЛЕЙ И АУТЕНТИФИКАЦИИ
// ============================================================================

enum UserRole {
  GUEST
  USER
  TRAINER
  DOCTOR
  NUTRITIONIST
  PSYCHOLOGIST
  SEXOLOGIST
  SPECIALIST
  LOCATION_ADMIN
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  phone             String?  @unique
  passwordHash      String
  role              UserRole @default(USER)
  isActive          Boolean  @default(true)
  isEmailVerified   Boolean  @default(false)
  isPhoneVerified   Boolean  @default(false)
  twoFactorEnabled  Boolean  @default(false)
  twoFactorSecret   String?
  lastLoginAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Связи с профилями
  profile           UserProfile?
  trainerProfile    TrainerProfile?
  doctorProfile     DoctorProfile?
  psychologistProfile PsychologistProfile?
  sexologistProfile SexologistProfile?
  nutritionistProfile NutritionistProfile?
  
  // Связи с другими модулями
  bodyAvatar        BodyAvatar?
  walletAddress     String?           @unique
  tokenBalance      Decimal           @default(0) @db.Decimal(18, 8)
  
  // Социальные связи
  posts             Post[]
  comments          Comment[]
  likes             Like[]
  followers         Follow[]          @relation("followers")
  following         Follow[]          @relation("following")
  sentMessages      Message[]         @relation("sender")
  receivedMessages  Message[]         @relation("receiver")
  chatMembers       ChatMember[]
  
  // Тренировки и активность
  workoutRecords    WorkoutRecord[]
  workoutPrograms   UserWorkoutProgram[]
  challenges        ChallengeParticipant[]
  achievements      UserAchievement[]
  
  // Здоровье
  medicalRecords    MedicalRecord[]
  mealLogs          MealLog[]
  mealPlans         UserMealPlan[]
  
  // Психология и ментальное здоровье
  moodLogs          MoodLog[]
  meditationSessions MeditationSession[]
  therapySessions   TherapySession[]     @relation("patient")
  
  // Сексология
  sexHealthRecords  SexHealthRecord[]
  intimacyLogs      IntimacyLog[]
  
  // Привычки и быт
  habits            Habit[]
  habitLogs         HabitLog[]
  dailyRoutines     DailyRoutine[]
  sleepLogs         SleepLog[]
  
  // Образование
  enrolledCourses   CourseEnrollment[]
  completedLessons  LessonCompletion[]
  
  // Покупки и подписки
  orders            Order[]
  subscriptions     UserSubscription[]
  locationAccess    LocationAccess[]
  
  // DAO участие
  daoVotes          DaoVote[]
  stakingRecords    StakingRecord[]
  
  // Уведомления
  notifications     Notification[]
  notificationSettings NotificationSettings?
  
  // Группы и сообщества
  groupMembers      GroupMember[]
  createdGroups     Group[]           @relation("groupCreator")

  // Реферальная система
  referralCode      ReferralCode?
  referrals         Referral[]        @relation("referrer")
  referredBy         Referral[]        @relation("referred")

  // Telegram
  telegramUser      TelegramUser?

  @@index([email])
  @@index([phone])
  @@index([walletAddress])
}

model UserProfile {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  firstName       String
  lastName        String
  displayName     String?
  bio             String?   @db.Text
  avatarUrl       String?
  coverImageUrl   String?
  dateOfBirth     DateTime?
  gender          Gender?
  
  // Физические параметры
  height          Float?    // в сантиметрах
  weight          Float?    // в килограммах
  bodyFatPercent  Float?
  
  // Локализация
  language        String    @default("ru")
  timezone        String    @default("Europe/Moscow")
  country         String?
  city            String?
  
  // Настройки приватности
  isProfilePublic Boolean   @default(true)
  showAge         Boolean   @default(false)
  showWeight      Boolean   @default(false)
  
  // Настройки темы
  themeId         String?
  theme           Theme?    @relation(fields: [themeId], references: [id])
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model BodyAvatar {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Схематичное представление тела
  bodyShape       Json     // Параметры фигуры
  muscleGroups    Json     // Состояние мышечных групп
  injuries        Json?    // Травмы и ограничения
  goals           Json     // Цели пользователя
  
  // Целевые показатели
  targetWeight    Float?
  targetBodyFat   Float?
  targetMuscle    Float?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============================================================================
// МОДУЛЬ СПЕЦИАЛИСТОВ (ТРЕНЕРЫ, ВРАЧИ, ПСИХОЛОГИ, СЕКСОЛОГИ, НУТРИЦИОЛОГИ)
// ============================================================================

model TrainerProfile {
  id                String             @id @default(uuid())
  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  specializations   String[]           // ["фитнес", "йога", "силовые"]
  certifications    Certification[]
  experience        Int                // Лет опыта
  bio               String?            @db.Text
  
  // Рейтинг и статистика
  rating            Float              @default(0)
  reviewsCount      Int                @default(0)
  clientsCount      Int                @default(0)
  
  // Верификация
  isVerified        Boolean            @default(false)
  verificationStatus VerificationStatus @default(PENDING)
  verifiedAt        DateTime?
  
  // Страница тренера
  trainerPage       TrainerPage?
  
  // Связи
  workoutPrograms   WorkoutProgram[]
  trainerLocations  TrainerLocation[]
  
  // Доступность
  isAvailableOnline Boolean            @default(true)
  isAvailableOffline Boolean           @default(true)
  hourlyRate        Decimal?           @db.Decimal(10, 2)
  hourlyRateTokens  Decimal?           @db.Decimal(18, 8)
  
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model DoctorProfile {
  id                String             @id @default(uuid())
  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  specializations   String[]           // ["терапевт", "эндокринолог", "кардиолог"]
  medicalLicense    String
  certifications    Certification[]
  experience        Int
  bio               String?            @db.Text
  
  // Рейтинг
  rating            Float              @default(0)
  reviewsCount      Int                @default(0)
  patientsCount     Int                @default(0)
  
  // Верификация (обязательна для врачей)
  isVerified        Boolean            @default(false)
  verificationStatus VerificationStatus @default(PENDING)
  verifiedAt        DateTime?
  
  // Консультации
  consultations     MedicalConsultation[]
  
  // Тарифы
  consultationRate  Decimal?           @db.Decimal(10, 2)
  consultationRateTokens Decimal?      @db.Decimal(18, 8)
  
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model PsychologistProfile {
  id                String             @id @default(uuid())
  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  specializations   String[]           // ["КПТ", "гештальт", "семейная терапия"]
  license           String?
  certifications    Certification[]
  experience        Int
  bio               String?            @db.Text
  approaches        String[]           // Методы терапии
  
  // Рейтинг
  rating            Float              @default(0)
  reviewsCount      Int                @default(0)
  clientsCount      Int                @default(0)
  
  // Верификация
  isVerified        Boolean            @default(false)
  verificationStatus VerificationStatus @default(PENDING)
  
  // Сессии
  therapySessions   TherapySession[]
  
  // Тарифы
  sessionRate       Decimal?           @db.Decimal(10, 2)
  sessionRateTokens Decimal?           @db.Decimal(18, 8)
  
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model SexologistProfile {
  id                String             @id @default(uuid())
  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  specializations   String[]           // ["сексуальная дисфункция", "парная терапия", "либидо"]
  license           String?
  certifications    Certification[]
  experience        Int
  bio               String?            @db.Text
  approaches        String[]
  
  // Рейтинг
  rating            Float              @default(0)
  reviewsCount      Int                @default(0)
  clientsCount      Int                @default(0)
  
  // Верификация
  isVerified        Boolean            @default(false)
  verificationStatus VerificationStatus @default(PENDING)
  
  // Консультации
  consultations     SexologyConsultation[]
  
  // Тарифы
  sessionRate       Decimal?           @db.Decimal(10, 2)
  sessionRateTokens Decimal?           @db.Decimal(18, 8)
  
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model NutritionistProfile {
  id                String             @id @default(uuid())
  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  specializations   String[]           // ["снижение веса", "спортивное питание", "кето"]
  certifications    Certification[]
  experience        Int
  bio               String?            @db.Text
  
  // Рейтинг
  rating            Float              @default(0)
  reviewsCount      Int                @default(0)
  clientsCount      Int                @default(0)
  
  // Верификация
  isVerified        Boolean            @default(false)
  verificationStatus VerificationStatus @default(PENDING)
  
  // Планы питания
  mealPlans         MealPlan[]
  
  // Тарифы
  consultationRate  Decimal?           @db.Decimal(10, 2)
  consultationRateTokens Decimal?      @db.Decimal(18, 8)
  
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Certification {
  id                String   @id @default(uuid())
  title             String
  issuingOrganization String
  issueDate         DateTime
  expiryDate        DateTime?
  certificateNumber String?
  documentUrl       String?
  isVerified        Boolean  @default(false)
  
  // Связи с профилями
  trainerProfileId  String?
  trainerProfile    TrainerProfile? @relation(fields: [trainerProfileId], references: [id])
  doctorProfileId   String?
  doctorProfile     DoctorProfile? @relation(fields: [doctorProfileId], references: [id])
  psychologistProfileId String?
  psychologistProfile PsychologistProfile? @relation(fields: [psychologistProfileId], references: [id])
  sexologistProfileId String?
  sexologistProfile SexologistProfile? @relation(fields: [sexologistProfileId], references: [id])
  nutritionistProfileId String?
  nutritionistProfile NutritionistProfile? @relation(fields: [nutritionistProfileId], references: [id])
  
  createdAt         DateTime @default(now())
}

// ============================================================================
// МОДУЛЬ СТРАНИЦЫ ТРЕНЕРА И ТЕМЫ
// ============================================================================

model TrainerPage {
  id              String          @id @default(uuid())
  trainerId       String          @unique
  trainer         TrainerProfile  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  
  slug            String          @unique
  title           String
  description     String?         @db.Text
  
  // Тема оформления
  themeId         String?
  theme           Theme?          @relation(fields: [themeId], references: [id])
  
  // Конфигурация модулей
  modulesConfig   Json            // Какие модули включены и их настройки
  
  // Статистика
  viewsCount      Int             @default(0)
  followersCount  Int             @default(0)
  subscribersCount Int            @default(0)
  
  isPublished     Boolean         @default(false)
  publishedAt     DateTime?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@index([slug])
}

model Theme {
  id              String        @id @default(uuid())
  name            String
  description     String?
  version         String
  author          String
  
  // Наследование тем
  baseThemeId     String?
  baseTheme       Theme?        @relation("themeInheritance", fields: [baseThemeId], references: [id])
  childThemes     Theme[]       @relation("themeInheritance")
  
  // Стили
  colors          Json          // Палитра цветов
  fonts           Json          // Шрифты
  spacing         Json?         // Отступы
  borderRadius    Json?         // Скругления
  shadows         Json?         // Тени
  animations      Json?         // Анимации
  
  // Ресурсы
  previewImageUrl String?
  packageUrl      String?       // URL пакета темы
  
  // Модули темы
  themeModules    ThemeModule[]
  
  // Использование
  userProfiles    UserProfile[]
  trainerPages    TrainerPage[]
  
  isPublic        Boolean       @default(true)
  isOfficial      Boolean       @default(false)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model ThemeModule {
  id              String   @id @default(uuid())
  themeId         String
  theme           Theme    @relation(fields: [themeId], references: [id], onDelete: Cascade)
  
  name            String
  componentPath   String
  configSchema    Json?    // JSON Schema для настроек
  dependencies    String[] // ID других модулей
  
  isRequired      Boolean  @default(false)
  
  createdAt       DateTime @default(now())
}

// ============================================================================
// МОДУЛЬ ТРЕНИРОВОК И ФИТНЕСА
// ============================================================================

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum MuscleGroup {
  CHEST
  BACK
  SHOULDERS
  BICEPS
  TRICEPS
  FOREARMS
  ABS
  OBLIQUES
  LOWER_BACK
  GLUTES
  QUADRICEPS
  HAMSTRINGS
  CALVES
  FULL_BODY
  CARDIO
}

model WorkoutProgram {
  id              String          @id @default(uuid())
  trainerId       String
  trainer         TrainerProfile  @relation(fields: [trainerId], references: [id])
  
  title           String
  description     String?         @db.Text
  coverImageUrl   String?
  
  difficulty      DifficultyLevel
  duration        Int             // Длительность программы в днях
  workoutsPerWeek Int
  
  targetGoals     String[]        // ["похудение", "набор массы"]
  targetMuscles   MuscleGroup[]
  equipment       String[]        // Необходимое оборудование
  
  // Цены
  isFree          Boolean         @default(false)
  priceFiat       Decimal?        @db.Decimal(10, 2)
  priceTokens     Decimal?        @db.Decimal(18, 8)
  
  // Статистика
  enrollmentsCount Int            @default(0)
  rating          Float           @default(0)
  reviewsCount    Int             @default(0)
  
  // Упражнения
  exercises       Exercise[]
  workoutDays     WorkoutDay[]
  
  // Пользователи
  userPrograms    UserWorkoutProgram[]
  
  isPublished     Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model WorkoutDay {
  id              String          @id @default(uuid())
  programId       String
  program         WorkoutProgram  @relation(fields: [programId], references: [id], onDelete: Cascade)
  
  dayNumber       Int
  title           String
  description     String?
  
  exercises       WorkoutDayExercise[]
  
  restDay         Boolean         @default(false)
  
  createdAt       DateTime        @default(now())
}

model Exercise {
  id              String          @id @default(uuid())
  programId       String?
  program         WorkoutProgram? @relation(fields: [programId], references: [id])
  
  name            String
  description     String?         @db.Text
  instructions    String?         @db.Text
  
  targetMuscles   MuscleGroup[]
  secondaryMuscles MuscleGroup[]
  equipment       String[]
  
  imageUrl        String?
  videoUrl        String?
  thumbnailUrl    String?
  
  difficulty      DifficultyLevel
  
  // Стандартные параметры
  defaultSets     Int?
  defaultReps     Int?
  defaultDuration Int?            // В секундах
  defaultRestTime Int?            // В секундах
  
  workoutDays     WorkoutDayExercise[]
  workoutRecords  WorkoutRecord[]
  
  isPublic        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model WorkoutDayExercise {
  id              String      @id @default(uuid())
  workoutDayId    String
  workoutDay      WorkoutDay  @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
  exerciseId      String
  exercise        Exercise    @relation(fields: [exerciseId], references: [id])
  
  orderIndex      Int
  sets            Int
  reps            Int?
  duration        Int?        // В секундах
  restTime        Int?        // В секундах
  notes           String?
  
  createdAt       DateTime    @default(now())
}

model UserWorkoutProgram {
  id              String          @id @default(uuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  programId       String
  program         WorkoutProgram  @relation(fields: [programId], references: [id])
  
  startDate       DateTime
  endDate         DateTime?
  currentDay      Int             @default(1)
  
  progress        Float           @default(0) // Процент выполнения
  isCompleted     Boolean         @default(false)
  completedAt     DateTime?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  @@unique([userId, programId])
}

model WorkoutRecord {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  exerciseId      String?
  exercise        Exercise? @relation(fields: [exerciseId], references: [id])
  
  date            DateTime
  duration        Int       // В минутах
  
  sets            Int?
  reps            Int?
  weight          Float?    // В кг
  distance        Float?    // В км (для кардио)
  
  caloriesBurned  Int?
  heartRateAvg    Int?
  heartRateMax    Int?
  
  notes           String?
  mood            Int?      // 1-5
  difficulty      Int?      // 1-5 субъективная
  
  // Данные с гаджетов
  deviceData      Json?
  
  tokensEarned    Decimal   @default(0) @db.Decimal(18, 8)
  
  createdAt       DateTime  @default(now())
  
  @@index([userId, date])
}

// ============================================================================
// МОДУЛЬ МЕДИЦИНЫ И ЗДОРОВЬЯ
// ============================================================================

enum MedicalRecordType {
  BLOOD_TEST
  HORMONE_TEST
  VITAMIN_TEST
  ALLERGY_TEST
  GENETIC_TEST
  ECG
  ULTRASOUND
  MRI
  CT_SCAN
  XRAY
  VACCINATION
  PRESCRIPTION
  DIAGNOSIS
  OTHER
}

model MedicalRecord {
  id              String            @id @default(uuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type            MedicalRecordType
  title           String
  description     String?           @db.Text
  
  // Результаты
  resultValue     String?
  resultUnit      String?
  referenceRange  String?
  isNormal        Boolean?
  
  // Данные
  data            Json?             // Структурированные данные
  documentUrl     String?           // Скан/документ
  
  // Источник
  provider        String?           // Лаборатория/клиника
  doctorName      String?
  
  date            DateTime
  expiryDate      DateTime?         // Для прививок и т.п.
  
  // Рекомендации
  recommendation  String?           @db.Text
  
  // Приватность
  isPrivate       Boolean           @default(true)
  sharedWith      String[]          // ID специалистов с доступом
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  @@index([userId, type])
  @@index([userId, date])
}

model MedicalConsultation {
  id              String        @id @default(uuid())
  doctorId        String
  doctor          DoctorProfile @relation(fields: [doctorId], references: [id])
  patientId       String
  
  scheduledAt     DateTime
  duration        Int           // В минутах
  
  status          String        @default("scheduled") // scheduled, completed, cancelled
  
  // Тип консультации
  isOnline        Boolean       @default(true)
  meetingUrl      String?
  locationId      String?
  
  // Содержание
  symptoms        String?       @db.Text
  diagnosis       String?       @db.Text
  prescription    String?       @db.Text
  recommendations String?       @db.Text
  
  // Оплата
  paidAmount      Decimal?      @db.Decimal(10, 2)
  paidTokens      Decimal?      @db.Decimal(18, 8)
  paymentStatus   String        @default("pending")
  
  // Отзыв
  rating          Int?
  review          String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// ============================================================================
// МОДУЛЬ ПИТАНИЯ И НУТРИЦИОЛОГИИ
// ============================================================================

model MealPlan {
  id              String              @id @default(uuid())
  nutritionistId  String
  nutritionist    NutritionistProfile @relation(fields: [nutritionistId], references: [id])
  
  title           String
  description     String?             @db.Text
  coverImageUrl   String?
  
  // Целевые показатели
  targetCalories  Int
  targetProteins  Float               // В граммах
  targetFats      Float
  targetCarbs     Float
  targetFiber     Float?
  
  // Характеристики
  duration        Int                 // В днях
  mealsPerDay     Int                 @default(3)
  dietType        String[]            // ["кето", "вегетарианство", "low-carb"]
  restrictions    String[]            // ["без глютена", "без лактозы"]
  
  // Цены
  isFree          Boolean             @default(false)
  priceFiat       Decimal?            @db.Decimal(10, 2)
  priceTokens     Decimal?            @db.Decimal(18, 8)
  
  // Статистика
  enrollmentsCount Int                @default(0)
  rating          Float               @default(0)
  
  // Блюда
  mealItems       MealItem[]
  dayPlans        MealDayPlan[]
  
  // Пользователи
  userPlans       UserMealPlan[]
  
  isPublished     Boolean             @default(false)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model MealDayPlan {
  id              String     @id @default(uuid())
  mealPlanId      String
  mealPlan        MealPlan   @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  
  dayNumber       Int
  meals           MealDayItem[]
  
  totalCalories   Int?
  totalProteins   Float?
  totalFats       Float?
  totalCarbs      Float?
  
  createdAt       DateTime   @default(now())
}

model MealItem {
  id              String        @id @default(uuid())
  mealPlanId      String?
  mealPlan        MealPlan?     @relation(fields: [mealPlanId], references: [id])
  
  name            String
  description     String?
  recipe          String?       @db.Text
  imageUrl        String?
  
  // Пищевая ценность на порцию
  portionSize     Float         // В граммах
  calories        Int
  proteins        Float
  fats            Float
  carbs           Float
  fiber           Float?
  sugar           Float?
  sodium          Float?
  
