{
  "name": "nexus-vita",
  "version": "1.0.0",
  "description": "Экосистема здоровья, тренировок и тренеров",
  "repository": {
    "type": "git",
    "url": "https://github.com/TimurSama/NexusVita.git"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "build": "cd frontend && npm run build && cd ../backend && npm run build",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install"
  },
  "keywords": ["health", "fitness", "trainers", "ecosystem", "blockchain", "web3"],
  "author": "TimurSama",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}

